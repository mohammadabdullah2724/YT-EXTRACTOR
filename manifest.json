{
  "manifest_version": 3,
  "name": "YT Channel Link Extractor",
  "version": "2.0.0",
  "description": "Extract all video links from any YouTube channel page instantly.",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://www.youtube.com/*", "https://img.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Link Extractor"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
